# -- Supabase --------------------------------------------------
# Found in: Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Paste your Supabase anon key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -- SelfOS modules -------------------------------------------
# Optional. By default every module is enabled.
# Use a comma-separated allowlist...
# NEXT_PUBLIC_SELFOS_MODULES=notes,tasks,goals,finance,fitness,education,automation
# ...or disable only a few modules.
# NEXT_PUBLIC_SELFOS_DISABLED_MODULES=education,finance
# Optional comma-separated list for Next.js development origins.
# NEXT_ALLOWED_DEV_ORIGINS=my-device.local

# Never expose this key to the frontend.
# Use it only for server-side features that require admin access.
# SUPABASE_SERVICE_ROLE_KEY=

# -- Finance: ETF prices --------------------------------------
# Server-only key used to refresh ETF prices from Twelve Data.
TWELVE_DATA_API_KEY=

# Secret for POST /api/finance/investments/cron when called by Vercel Cron or another scheduler.
FINANCE_CRON_SECRET=
